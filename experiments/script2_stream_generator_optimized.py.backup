# script2_stream_generator_optimized.py
import os
import struct
from collections import defaultdict

PTIbin_DIR = "PTIbin"
OUTPUT_STREAM = "universal_lib.bin"
NEW_DATA_SIZE = 10 * 1024 * 1024

# ------------------------------------------------------------
# Step 1: read all .bin files efficiently
# ------------------------------------------------------------
all_data = bytearray()
for bin_file in sorted(os.listdir(PTIbin_DIR)):
    if bin_file.endswith(".bin"):
        with open(os.path.join(PTIbin_DIR, bin_file), "rb") as f:
            all_data.extend(f.read())

print(f"Original PTIbin total: {len(all_data)} bytes")

with open(OUTPUT_STREAM, "wb") as f:
    f.write(all_data)

# ------------------------------------------------------------
# Step 2: build Markov model (order-4) using integer contexts
# ------------------------------------------------------------
if len(all_data) < 5:
    raise RuntimeError("Not enough data")

model = defaultdict(list)   # key: int (4 bytes) -> list of next bytes (int)
# Use memoryview for faster access
data_view = memoryview(all_data)
max_pos = len(all_data) - 4

for i in range(max_pos):
    # Pack 4 bytes into a 32-bit integer (little-endian)
    ctx = (data_view[i] << 24) | (data_view[i+1] << 16) | (data_view[i+2] << 8) | data_view[i+3]
    nxt = data_view[i+4]
    model[ctx].append(nxt)

print(f"Model built with {len(model)} unique contexts")

# ------------------------------------------------------------
# Step 3: generate deterministic stream (100 MB)
# ------------------------------------------------------------
# initial context from last 4 bytes
ctx = (data_view[-4] << 24) | (data_view[-3] << 16) | (data_view[-2] << 8) | data_view[-1]
generated = bytearray()
pos_in_model = {ctx: 0 for ctx in model}   # keep cycle pointers

while len(generated) < NEW_DATA_SIZE:
    if ctx in model:
        lst = model[ctx]
        idx = pos_in_model[ctx]
        nxt = lst[idx]
        pos_in_model[ctx] = (idx + 1) % len(lst)
    else:
        # fallback: repeat original bytes cyclically
        nxt = all_data[len(generated) % len(all_data)]
    generated.append(nxt)
    # update context: shift left, add new byte, mask to 32 bits
    ctx = ((ctx << 8) | nxt) & 0xFFFFFFFF

print(f"Generated {len(generated)} bytes")

# ------------------------------------------------------------
# Step 4: append
# ------------------------------------------------------------
with open(OUTPUT_STREAM, "ab") as f:
    f.write(generated)

print(f"Final size: {len(all_data) + len(generated)} bytes")# 2026-05-11T08:00:00Z | Initial commit: Add script2_stream_generator_optimized.py
